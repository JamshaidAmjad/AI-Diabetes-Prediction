# Python cache and artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# OS / editor files
.DS_Store
.vscode/
.idea/

# Output artifacts — commit figures and reports, ignore large trained model binaries
outputs/models/*
outputs/figures/*
outputs/reports/*
!outputs/models/.gitkeep
!outputs/figures/.gitkeep
!outputs/figures/*.png
!outputs/reports/.gitkeep
!outputs/reports/*.json
!outputs/reports/*.docx
!outputs/reports/*.pptx

# Data files — commit processed splits and source CSV, ignore large binaries
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/raw/diabetes.csv
!data/processed/.gitkeep
!data/processed/*.npy
!data/processed/selected_features.txt

